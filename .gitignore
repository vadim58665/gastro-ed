# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# claude
.claude/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# scraped data & scripts (keep classify-cards.ts)
/scraped_data/
/scripts/*.py
/scripts/__pycache__/
/scripts/captured_data/
/scripts/run_capture.sh
/тесты/
/тесты_backup_*.tar.gz
/задачи/
/public/download_images.sh
/public/images/
.superpowers/

# playwright MCP artifacts
/.playwright-mcp/

# batch-generation outputs (LLM scripts)
/hint-batch-*-result.json
/explain-batch-*-result.json

# wiki raw binaries (markdown sources committed, binaries not)
wiki/raw/**/*.pdf
wiki/raw/**/*.docx
wiki/raw/**/*.pptx
wiki/raw/**/*.xlsx
